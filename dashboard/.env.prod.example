# Production Environment Variables
# Copy to .env and configure for your deployment

# Domain Configuration
# This single variable configures:
# - Main site: https://${DOMAIN}
# - API endpoint: https://api.${DOMAIN}
# - Backend BASE_URL in docker-compose.prod.yml
# - Backend CORS_ORIGIN in docker-compose.prod.yml
DOMAIN=yourdomain.com

# SSL Certificate Paths (optional)
# If not set, defaults to Let's Encrypt paths:
# - /etc/letsencrypt/live/${DOMAIN}/fullchain.pem
# - /etc/letsencrypt/live/${DOMAIN}/privkey.pem
#
# Custom certificate example:
# SSL_CERT=/etc/ssl/certs/yourdomain.crt
# SSL_KEY=/etc/ssl/private/yourdomain.key

# Notes
# - The prebuilt frontend image auto-targets https://api.${DOMAIN}/api at runtime.
# - Keep application secrets in dashboard/secrets/*.txt, not in this file.

# Docker Image Configuration
GITHUB_OWNER=wford26
VERSION=latest
