# Production Environment Configuration
# Used only at build time (`npm run build` or `docker build`).
# The published GHCR frontend image does not read this file at container startup.

# Optional API URL override.
# If omitted, the app auto-detects:
# - http://localhost:3001/api in local development
# - https://api.<current-domain>/api when served from your production site
VITE_API_URL=https://api.yourdomain.com/api

# Enable production optimizations
VITE_APP_ENV=production

# Optional: Analytics/monitoring
# VITE_ANALYTICS_ID=your_analytics_id
