# Production Environment Variables Example
# Copy this to .env when you run the backend directly or build your own image.
# `docker-compose.prod.yml` already provides DATABASE_HOST/PORT/NAME, BASE_URL,
# and CORS_ORIGIN for the standard BetTrack production stack.

# Database Configuration
# The backend can build DATABASE_URL from these component variables.
DATABASE_TYPE=postgresql
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=sports_betting_dashboard
DATABASE_USER=sports_user
DATABASE_PASSWORD=secure_password
# Optional explicit URL override:
# DATABASE_URL=postgresql://sports_user:secure_password@postgres:5432/sports_betting_dashboard

# Secrets
# For Docker secrets, create the matching files in ../secrets/ instead.
ODDS_API_KEY=your_odds_api_key_here
SESSION_SECRET=your_64_character_hex_string_here
JWT_SECRET=your_64_character_hex_string_here

# Server Configuration
NODE_ENV=production
PORT=3001
LOG_LEVEL=info
CORS_ORIGIN=https://yourdomain.com
BASE_URL=https://api.yourdomain.com

# Automated Job Intervals (in minutes)
ODDS_SYNC_INTERVAL=1440
OUTCOME_CHECK_INTERVAL=5

# Prisma Migration
AUTO_MIGRATE=true

# OAuth Configuration (optional)
AUTH_MODE=none
# MICROSOFT_CLIENT_ID=your-client-id
# MICROSOFT_CLIENT_SECRET=your-client-secret
# MICROSOFT_TENANT_ID=common
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ========================================
# DOCKER SECRETS SETUP (Recommended for Production)
# ========================================
#
# 1. Create secrets directory:
#    mkdir -p ../secrets
#
# 2. Add your secrets (one value per file, no trailing newline):
#    echo -n "sports_user" > ../secrets/db_user.txt
#    echo -n "secure_password" > ../secrets/db_password.txt
#    echo -n "your_api_key_here" > ../secrets/odds_api_key.txt
#    echo -n "$(openssl rand -hex 32)" > ../secrets/session_secret.txt
#    echo -n "$(openssl rand -hex 32)" > ../secrets/jwt_secret.txt
#
# 3. Secure the files:
#    chmod 600 ../secrets/*.txt
#
# 4. Deploy with docker compose:
#    docker compose -f docker-compose.prod.yml up -d
#
# Docker secrets override matching values from the container environment and .env file.
# See ../secrets/README.md for more details.
